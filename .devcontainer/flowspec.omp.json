{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "version": 2,
  "final_space": true,
  "console_title_template": "{{ .Shell }} in {{ .Folder }}",
  "blocks": [
    {
      "type": "prompt",
      "alignment": "left",
      "segments": [
        {
          "type": "os",
          "style": "powerline",
          "powerline_symbol": "\ue0b0",
          "foreground": "#ffffff",
          "background": "#d75f00",
          "template": " {{ if .WSL }}WSL at {{ end }}{{.Icon}} "
        },
        {
          "type": "git",
          "style": "powerline",
          "powerline_symbol": "\ue0b0",
          "foreground": "#ffffff",
          "background": "#d75f00",
          "background_templates": [
            "{{ if or (.Working.Changed) (.Staging.Changed) }}#d75f00{{ end }}",
            "{{ if and (gt .Ahead 0) (gt .Behind 0) }}#d75f00{{ end }}",
            "{{ if gt .Ahead 0 }}#d75f00{{ end }}",
            "{{ if gt .Behind 0 }}#d75f00{{ end }}"
          ],
          "template": " {{ .HEAD }}{{if .BranchStatus }} {{ .BranchStatus }}{{ end }}{{ if .Working.Changed }} \uf044 {{ .Working.String }}{{ end }}{{ if and (.Working.Changed) (.Staging.Changed) }} |{{ end }}{{ if .Staging.Changed }} \uf046 {{ .Staging.String }}{{ end }}{{ if gt .StashCount 0 }} \ueb4b {{ .StashCount }}{{ end }} ",
          "properties": {
            "branch_icon": "\ue0a0 ",
            "fetch_stash_count": true,
            "fetch_status": true,
            "fetch_upstream_icon": true
          }
        },
        {
          "type": "path",
          "style": "powerline",
          "powerline_symbol": "\ue0b0",
          "foreground": "#ffffff",
          "background": "#0077c2",
          "template": " \uf07c {{ path .Path .Location }} ",
          "properties": {
            "style": "full"
          }
        }
      ]
    },
    {
      "type": "prompt",
      "alignment": "right",
      "segments": [
        {
          "type": "status",
          "style": "plain",
          "foreground": "#98c379",
          "foreground_templates": [
            "{{ if gt .Code 0 }}#ff6b6b{{ end }}"
          ],
          "template": "{{ if eq .Code 0 }}\u2714{{ else }}\u2718{{ end }} ",
          "properties": {
            "always_enabled": true
          }
        },
        {
          "type": "text",
          "style": "plain",
          "foreground": "#61afef",
          "template": "{{ .HostName }} "
        },
        {
          "type": "text",
          "style": "plain",
          "foreground": "#ffffff",
          "template": "\ud83c\uddee\ud83c\uddea "
        },
        {
          "type": "time",
          "style": "plain",
          "foreground": "#d19a66",
          "template": "{{ .CurrentDate | date \"15:04:05\" }} \u23f0"
        }
      ]
    },
    {
      "type": "prompt",
      "alignment": "left",
      "newline": true,
      "segments": [
        {
          "type": "text",
          "style": "plain",
          "foreground": "#d75f00",
          "template": "\u2570\u2500"
        }
      ]
    }
  ],
  "transient_prompt": {
    "foreground": "#d75f00",
    "template": "\u276f "
  }
}
